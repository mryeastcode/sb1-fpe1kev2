# Supabase test harness environment (safe to share as a template; never commit real keys)
# Provide these values in CI secrets or local env before running harness
export SUPABASE_URL="https://your-project.supabase.co"
export SUPABASE_ANON_KEY="<your-anon-key>"
export SUPABASE_SERVICE_KEY="<your-service-key>"  # optional; if provided, harness will attempt admin flow
export TEST_USER_ID="<a real user_id from auth.users>"  # optional; if omitted, harness will attempt to fetch or run anon path

# If you seed a user, set TEST_USER_ID to the actual id to ensure deterministic tests
